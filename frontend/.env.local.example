# Copier vers .env.local pour le développement local.

# URL du backend Wagtail vue côté SERVEUR Next (SSR/SSG/ISR).
# En dev local : http://localhost:8000 ; en Docker : http://backend:8000
WAGTAIL_API_URL=http://localhost:8000

# URL du backend vue côté NAVIGATEUR (liens médias, fetch client éventuel).
NEXT_PUBLIC_WAGTAIL_API_URL=http://localhost:8000

# URL publique du site (sitemap, balises canoniques, Open Graph).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Secret partagé avec Wagtail pour /api/revalidate et la prévisualisation.
REVALIDATE_SECRET=dev-preview-secret
