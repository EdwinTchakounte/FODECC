# ─────────────────────────────────────────────────────────────────────
#  Backend FODECC — variables d'env de DÉVELOPPEMENT (copier vers backend/.env)
#  En dev, presque tout a une valeur par défaut sensée — ce fichier est optionnel.
# ─────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=dev-insecure-change-me
# En dev, config.settings.dev force SQLite quoi qu'il y ait ici.
# DATABASE_URL=postgres://fodecc:fodecc@localhost:5432/fodecc

# CORS : origine du front Next en local
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3010
# Prévisualisation des brouillons + revalidation ISR (front local)
HEADLESS_PREVIEW_CLIENT_URL=http://localhost:3000
PREVIEW_SECRET=dev-preview-secret
REVALIDATE_SECRET=dev-preview-secret
# NEXT_REVALIDATE_URL=http://localhost:3000/api/revalidate   # décommenter si le front local tourne
