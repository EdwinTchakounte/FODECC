# ─────────────────────────────────────────────────────────────────────
#  Backend FODECC — variables d'env de PRODUCTION (VPS Contabo)
#  Copier vers `backend/.env` SUR LE SERVEUR et remplir tous les __…__.
#  ⚠ Ne JAMAIS committer ce `.env` (il est .gitignored).
# ─────────────────────────────────────────────────────────────────────

# --- PostgreSQL ---
POSTGRES_DB=fodecc
POSTGRES_USER=fodecc
POSTGRES_PASSWORD=__MOT_DE_PASSE_FORT__
DATABASE_URL=postgres://fodecc:__MOT_DE_PASSE_FORT__@db:5432/fodecc

# --- Django / Wagtail ---
DJANGO_SETTINGS_MODULE=config.settings.prod
# Générer : python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=__CLE_ALEATOIRE_64_CARACTERES__
DJANGO_ALLOWED_HOSTS=backend.fodecc-vitrine.horus-lab.com,localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://backend.fodecc-vitrine.horus-lab.com
DJANGO_SECURE_SSL_REDIRECT=false           # Nginx gère déjà la redirection HTTP→HTTPS
# URL publique du CMS (URLs absolues : médias dans l'API, sitemap, emails…)
WAGTAIL_BASE_URL=https://backend.fodecc-vitrine.horus-lab.com

# --- CORS / front Vercel ---
# Origine(s) autorisée(s) à appeler l'API depuis le navigateur = la vitrine Vercel
CORS_ALLOWED_ORIGINS=https://fodecc-vitrine.horus-lab.com
# (ajouter ici les URL *.vercel.app de preview, séparées par des virgules, si besoin)

# --- Prévisualisation des brouillons (Draft Mode côté Next) ---
HEADLESS_PREVIEW_CLIENT_URL=https://fodecc-vitrine.horus-lab.com
# Secret PARTAGÉ avec Vercel : doit être identique à REVALIDATE_SECRET côté Next
PREVIEW_SECRET=__SECRET_PARTAGE_AVEC_VERCEL__
REVALIDATE_SECRET=__SECRET_PARTAGE_AVEC_VERCEL__
# Endpoint Next appelé après publication d'une page (revalidation ISR)
NEXT_REVALIDATE_URL=https://fodecc-vitrine.horus-lab.com/api/revalidate

# --- Email (notifications Wagtail) — optionnel ---
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=no-reply@horus-lab.com

# --- Let's Encrypt (utilisé par deploy/init-letsencrypt.sh) ---
LETSENCRYPT_EMAIL=tchambaedwin@gmail.com
CERTBOT_DOMAIN=backend.fodecc-vitrine.horus-lab.com
